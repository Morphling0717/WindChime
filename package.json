{
  "name": "@windchime/embed",
  "version": "0.3.0",
  "description": "WindChime 匿名提问箱 — 可嵌入的发送组件与管理收件面板（源码或 dist）",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./styles/windchime.css": "./dist/styles/windchime.css"
  },
  "files": [
    "dist",
    "src/styles"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "prepare": "npm run build",
    "build": "tsc -p tsconfig.build.json && mkdir -p dist/styles && cp src/styles/windchime.css dist/styles/windchime.css",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "tailwindcss": "^3.4.0 || ^4.0.0",
    "qrcode": "^1.5.0"
  },
  "peerDependenciesMeta": {
    "tailwindcss": {
      "optional": true
    },
    "qrcode": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/qrcode": "^1.5.5",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "qrcode": "^1.5.4",
    "typescript": "^5.0.0"
  }
}
